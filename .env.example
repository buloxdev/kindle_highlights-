# Required unless you store it in macOS Keychain service `kindle_highlights.amazon.email`
AMAZON_EMAIL=you@example.com

# Optional if using keychain service `kindle_highlights.amazon.password`
# AMAZON_PASSWORD=your_password_here

# Optional recipient for weekly highlight emails.
# If unset, weekly email command falls back to AMAZON_EMAIL or keychain services.
# WEEKLY_HIGHLIGHT_EMAIL=you@example.com

# Optional: set this when your Amazon account uses a specific marketplace domain.
# AMAZON_NOTEBOOK_URL=https://read.amazon.com/notebook

# Optional keychain account label (default: default)
# KINDLE_KEYCHAIN_ACCOUNT=default
